# Backend API base URL (no trailing slash). Must be your App Service / Kestrel URL + /api — NOT the Static Web Apps hostname.
# If this is missing at build time, the browser will call the static site origin and POSTs will fail (e.g. 405).
# Set the same variable in Azure Static Web Apps → Configuration → Application settings for the build pipeline, or in GitHub Actions env for `npm run build`.
# Local:   http://localhost:5000/api  (or http://localhost:5001/api if your API listens there)
# Azure:   https://your-app.azurewebsites.net/api
# Used for login, reports, and GET /api/dashboard (client & accountant portals).
VITE_API_BASE_URL=https://your-app.azurewebsites.net/api

# Optional: Supabase (if used elsewhere)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
