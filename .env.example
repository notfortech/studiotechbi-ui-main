# Backend API base URL — must match the same host as Swagger (include /api if backend uses it)
# Use HTTPS if Swagger uses HTTPS. Restart dev server after changing.
# Local:   http://localhost:5000/api
# HTTPS:   https://your-api.com/api
# Azure:   https://your-app.azurewebsites.net/api
VITE_API_BASE_URL=http://localhost:5000/api

# Optional: Supabase (if used elsewhere)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
